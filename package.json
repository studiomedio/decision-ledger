{
  "name": "decision-ledger",
  "displayName": "Decision Ledger",
  "description": "Surface Architectural Decision Records in the context of the code they govern.",
  "version": "1.0.0",
  "publisher": "studiomedio",
  "license": "MIT",
  "icon": "media/icon.png",
  "pricing": "Free",
  "homepage": "https://decisionledger.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/studiomedio/decision-ledger"
  },
  "bugs": {
    "url": "https://github.com/studiomedio/decision-ledger/issues"
  },
  "galleryBanner": {
    "color": "#152640",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "adr",
    "architecture",
    "decision record",
    "madr",
    "documentation"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "Decision Ledger",
      "properties": {
        "decisionLedger.folder": {
          "type": "string",
          "default": "docs/adr",
          "description": "Workspace-relative folder where ADR markdown files live."
        },
        "decisionLedger.fileGlob": {
          "type": "string",
          "default": "**/*.md",
          "description": "Glob (relative to the ADR folder) matching record files."
        },
        "decisionLedger.codeLens.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show a CodeLens at the top of files governed by an ADR."
        },
        "decisionLedger.anchor.keywords": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["dl:adr", "@adr"],
          "description": "Keywords that mark an inline ADR anchor in a code comment, e.g. `// dl:adr 0042`."
        },
        "decisionLedger.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Warn in the Problems panel about dangling anchors and code governed by superseded/deprecated records."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "decisionLedger",
          "title": "Decision Ledger",
          "icon": "media/ledger.svg"
        }
      ]
    },
    "views": {
      "decisionLedger": [
        {
          "id": "decisionLedger.records",
          "name": "Decisions",
          "icon": "media/ledger.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "decisionLedger.records",
        "contents": "No decision records found in this workspace.\n[New Decision Record](command:decisionLedger.newAdr)\nRecords are markdown files in [docs/adr](command:workbench.action.openSettings?%22decisionLedger.folder%22)."
      }
    ],
    "commands": [
      {
        "command": "decisionLedger.newAdr",
        "title": "New Decision Record",
        "category": "Decision Ledger",
        "icon": "$(add)"
      },
      {
        "command": "decisionLedger.openAdr",
        "title": "Open Decision Record…",
        "category": "Decision Ledger"
      },
      {
        "command": "decisionLedger.showFileDecisions",
        "title": "Show Decisions for This File",
        "category": "Decision Ledger"
      },
      {
        "command": "decisionLedger.linkSelection",
        "title": "Link Selection to Decision Record",
        "category": "Decision Ledger"
      },
      {
        "command": "decisionLedger.search",
        "title": "Search Decision Records",
        "category": "Decision Ledger",
        "icon": "$(search)"
      },
      {
        "command": "decisionLedger.preview",
        "title": "Open Preview",
        "category": "Decision Ledger",
        "icon": "$(open-preview)"
      },
      {
        "command": "decisionLedger.refresh",
        "title": "Refresh",
        "category": "Decision Ledger",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "decisionLedger.search",
          "when": "view == decisionLedger.records",
          "group": "navigation@0"
        },
        {
          "command": "decisionLedger.newAdr",
          "when": "view == decisionLedger.records",
          "group": "navigation@1"
        },
        {
          "command": "decisionLedger.refresh",
          "when": "view == decisionLedger.records",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "decisionLedger.preview",
          "when": "view == decisionLedger.records && viewItem == adrRecord",
          "group": "inline"
        }
      ],
      "editor/context": [
        {
          "command": "decisionLedger.linkSelection",
          "when": "editorTextFocus && !editorReadonly",
          "group": "1_modification@100"
        }
      ],
      "commandPalette": [
        {
          "command": "decisionLedger.refresh",
          "when": "false"
        },
        {
          "command": "decisionLedger.preview",
          "when": "false"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^14.1.0",
    "minimatch": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0",
    "@vscode/vsce": "^3.2.0"
  },
  "allowScripts": {
    "esbuild@0.25.12": true
  }
}
